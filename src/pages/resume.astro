---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume — Portfolio">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Resume</h1>
    <a
      href="/resume.pdf"
      download
      class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition-colors"
    >
      Download PDF
    </a>
  </div>
  <p class="text-slate-500 dark:text-slate-400">
    Place your resume at <code class="text-sm bg-gray-100 dark:bg-slate-800 px-1 rounded">public/resume.pdf</code> and it will be served here.
  </p>
</BaseLayout>
