---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import SkillsJSON from '../components/SkillsJSON.astro';
import { timeline } from '../data/timeline';
import { skills } from '../data/skills';

const experience = timeline.filter((e) => e.color !== 'purple');
const education = timeline.filter((e) => e.color === 'purple');
---

<BaseLayout title="Resume — Portfolio">

  <!-- Header -->
  <div style="padding:2rem 0 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div style="display:flex;flex-direction:column;justify-content:flex-end;gap:16px;">
      <div>
        <div style="color:var(--muted);font-size:0.8rem;letter-spacing:0.15em;text-transform:uppercase;font-family:'JetBrains Mono',monospace;margin-bottom:8px;">// cat resume.md</div>
        <h1 style="color:var(--text);font-size:1.75rem;font-weight:700;font-family:'JetBrains Mono',monospace;letter-spacing:-0.02em;margin-bottom:4px;">Antoine Deval</h1>
        <p style="color:var(--cyan);font-size:0.875rem;font-family:'JetBrains Mono',monospace;">Data &amp; Web specialist</p>
      </div>
      <div style="display:flex;flex-direction:row;gap:8px;">
      <a
        href="/resume-en.pdf"
        download="Antoine_Deval_Resume_EN.pdf"
        style="align-self:flex-start;background:#238636;color:#fff;padding:8px 18px;border-radius:6px;font-size:0.75rem;font-family:'JetBrains Mono',monospace;text-decoration:none;transition:background 0.15s;"
        onmouseover="this.style.background='#2ea043'"
        onmouseout="this.style.background='#238636'"
      >
        ↓ Download PDF (EN)
      </a>
      <a
        href="/resume-fr.pdf"
        download="Antoine_Deval_Resume_FR.pdf"
        style="align-self:flex-start;background:#238636;color:#fff;padding:8px 18px;border-radius:6px;font-size:0.75rem;font-family:'JetBrains Mono',monospace;text-decoration:none;transition:background 0.15s;"
        onmouseover="this.style.background='#2ea043'"
        onmouseout="this.style.background='#238636'"
      >
        ↓ Download PDF (FR)
      </a>
      </div>
    </div>
    <img
      src="/images/projects/profile.png"
      alt="Antoine Deval"
      style="width:250px;height:250px;border-radius:50%;object-fit:cover;border:2px solid var(--border);flex-shrink:0;"
      onerror="this.style.display='none'"
    />
  </div>

  <!-- Experience -->
  <section style="padding:2rem 0;border-bottom:1px solid var(--border);">
    <div style="color:var(--muted);font-size:0.8rem;letter-spacing:0.15em;text-transform:uppercase;font-family:'JetBrains Mono',monospace;margin-bottom:1.25rem;">// experience</div>
    <Timeline entries={experience} />
  </section>

  <!-- Education -->
  <section style="padding:2rem 0;border-bottom:1px solid var(--border);">
    <div style="color:var(--muted);font-size:0.8rem;letter-spacing:0.15em;text-transform:uppercase;font-family:'JetBrains Mono',monospace;margin-bottom:1.25rem;">// education</div>
    <Timeline entries={education} />
  </section>

  <!-- Skills -->
  <section style="padding:2rem 0;">
    <div style="color:var(--muted);font-size:0.8rem;letter-spacing:0.15em;text-transform:uppercase;font-family:'JetBrains Mono',monospace;margin-bottom:1.25rem;">// skills.json</div>
    <SkillsJSON skills={skills} />
  </section>

</BaseLayout>
