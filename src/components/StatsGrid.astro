---
interface Stat {
  label: string;
  value: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 my-8">
  {stats.map((stat) => (
    <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-4 text-center">
      <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">{stat.value}</div>
      <div class="text-xs text-slate-500 dark:text-slate-400 mt-1">{stat.label}</div>
    </div>
  ))}
</div>
